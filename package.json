{
  "name": "automerge-dependabot",
  "version": "1.0.0",
  "description": "GitHub Action to automatically merge Dependabot pull requests",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "automerge-dependabot": "bin/automerge-dependabot"
  },
  "scripts": {
    "build": "npx rimraf ./dist && npx rollup --config rollup.config.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest --coverage",
    "lint": "eslint src/**/*.js",
    "prepare": "husky",
    "cli": "node bin/automerge-dependabot"
  },
  "keywords": [
    "github",
    "actions",
    "dependabot",
    "automerge"
  ],
  "author": "navikt",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.57.1"
  }
}
